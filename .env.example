# prbe-knowledge env vars (post-pivot — gateway lives at api.prbe.ai).
#
# Copy to .env.local and fill in. .env.local is gitignored.
#
# After the centralized webhook + OAuth gateway landed on prbe-backend,
# this service no longer holds:
#   - webhook signing secrets (SLACK_SIGNING_SECRET, GITHUB_WEBHOOK_SECRET,
#     LINEAR_WEBHOOK_SECRET, SENTRY_WEBHOOK_SECRET)
#   - OAuth client_ids or GITHUB_APP_SLUG (gateway builds authorize URLs)
#   - any *_OAUTH_REDIRECT_URI (gateway is the redirect target)
#   - DASHBOARD_BASE_URL (gateway owns the post-OAuth dashboard redirect)
# Don't set them on Fly. Connector code paths that referenced them are
# dead in prod (still used by tests in tests/handlers/* via fixtures).

# --- Database ---------------------------------------------------------------
# DATABASE_URL       — asyncpg (runtime), plain postgresql:// scheme
# DATABASE_URL_SYNC  — alembic (migrations), postgresql+psycopg:// scheme
DATABASE_URL=postgresql://prbe:prbe@localhost:5432/prbe_knowledge
DATABASE_URL_SYNC=postgresql+psycopg://prbe:prbe@localhost:5432/prbe_knowledge

# --- Object storage (MinIO local; R2 in prod) -------------------------------
# Per-tenant buckets store raw webhook payload archives. The bucket is
# created at customer-provisioning time on prbe-backend; this service
# writes to it from the worker (and lazily ensures it on the
# forwarded-webhook handler before each put).
R2_ENDPOINT_URL=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_REGION=auto

# --- LLM / embedding providers ---------------------------------------------
# OpenAI: text-embedding-3-large for chunk embeddings.
OPENAI_API_KEY=sk-...
# Anthropic: Haiku query router + Sonnet synthesis; also drives Claude Code
# unit extraction (qa, code_change, decision, file_ref).
ANTHROPIC_API_KEY=sk-ant-...
# Claude Code unit extraction model (Anthropic). Default is the latest Sonnet.
CLAUDE_CODE_EXTRACTION_MODEL=claude-sonnet-4-6
# Claude Code session-completer cadence: idle minutes after which the cron
# enqueues a finalize event so the worker can extract units.
CLAUDE_CODE_SESSION_IDLE_MINUTES=5
# Google: Gemini for entity extraction (if enabled).
GOOGLE_API_KEY=

# --- Internal-knowledge API key --------------------------------------------
# Shared secret prbe-backend sends as X-Internal-Knowledge-Key on
# /api/* and /webhooks/*. The public surface (/query, /retrieve) uses
# per-tenant Bearer keys instead.
# Generate via: openssl rand -hex 32
INTERNAL_KNOWLEDGE_API_KEY=

# --- Token encryption (Fernet) ---------------------------------------------
# Encrypts OAuth + paste-an-API-key tokens at rest in
# integration_tokens.access_token_encrypted.
# Generate via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Per-source OAuth CLIENT SECRETS (token exchange happens here) ---------
# Used by /api/oauth/{source}/exchange (called by the gateway after it
# verifies HMAC-signed state). Public client_ids and webhook signing
# secrets live on prbe-backend, not here.
SLACK_CLIENT_SECRET=
LINEAR_CLIENT_SECRET=
NOTION_CLIENT_SECRET=
SENTRY_CLIENT_SECRET=

# --- GitHub App ------------------------------------------------------------
# GitHub uses a GitHub App (not OAuth) — the App ID + private key mint
# the JWT used to fetch installation access tokens.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# --- Observability (optional) ----------------------------------------------
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_HEADERS=

# --- Production hostnames (for reference) ----------------------------------
# Ingestion service:  https://ingest.prbe.ai
# Retrieval service:  https://query.prbe.ai
# Public surface:     https://api.prbe.ai  (prbe-backend gateway)
