# Probe knowledge engine — configuration.
#
#   cp .env.example .env   &&   docker compose up
#
# For `docker compose up`, the only values you MUST fill are a GOOGLE_API_KEY
# (embeddings) and one LLM key. Compose sets DATABASE_URL / object-store URLs
# for you (see docker-compose.yml); set them yourself only for a bare/Helm run.
#
# Two modes, one codebase:
#   - SELF-HOST (community): set DEFAULT_CUSTOMER_ID + KNOWLEDGE_API_TOKEN, leave
#     the "HOSTED ONLY" block blank. Single tenant, no control plane.
#   - HOSTED (multi-tenant): set the "HOSTED ONLY" block; leave the single-tenant
#     vars blank. Tenancy + auth come from the control plane.

# ============================================================================
# REQUIRED
# ============================================================================

# --- Database (Postgres 16 + pgvector + pg_trgm + btree_gin) ----------------
# Compose sets these to the bundled Postgres. For a bare/managed Postgres,
# point them at it. SYNC uses the psycopg driver (alembic); the other is asyncpg.
DATABASE_URL=postgresql://prbe:prbe@localhost:5432/prbe_knowledge
DATABASE_URL_SYNC=postgresql+psycopg://prbe:prbe@localhost:5432/prbe_knowledge

# --- Object storage (S3 / R2 / MinIO) — stores raw payload archives ---------
# Compose points these at the bundled MinIO.
R2_ENDPOINT_URL=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_REGION=auto
R2_BUCKET_PREFIX=prbe-knowledge

# --- Model providers --------------------------------------------------------
# Embeddings use Gemini (gemini-embedding); set GOOGLE_API_KEY. Synthesis/router
# use Anthropic by default; set at least one LLM key.
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Token encryption (Fernet) — encrypts connector tokens at rest ----------
# Required once you connect any OAuth/webhook source. Generate via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Single-tenant community mode -------------------------------------------
# DEFAULT_CUSTOMER_ID makes the engine a single tenant (RLS stays ON, trivially
# satisfied). KNOWLEDGE_API_TOKEN is the static bearer for /query + /retrieve
# (Authorization: Bearer <token>). Generate via: openssl rand -hex 32
DEFAULT_CUSTOMER_ID=default
KNOWLEDGE_API_TOKEN=

# --- MCP server (services/mcp) ----------------------------------------------
# Proxies search/query to retrieval over HTTP. Community auth: MCP_API_TOKEN is
# one shared bearer scoped to DEFAULT_CUSTOMER_ID (Authorization: Bearer
# <token>). KNOWLEDGE_QUERY_URL points at the retrieval service (compose:
# http://retrieval:8081). Token: openssl rand -hex 32
#
# MCP_AUTH_MODE auto-resolves — leave BLANK: with MCP_API_TOKEN set and no
# MCP_OAUTH_JWKS_URL it resolves to `static`; set a JWKS URL (hosted) and it
# resolves to `oauth`. Only set MCP_AUTH_MODE=static|oauth to force a mode.
MCP_AUTH_MODE=
MCP_API_TOKEN=
KNOWLEDGE_QUERY_URL=http://retrieval:8081

# ============================================================================
# CONNECTORS (optional — set the ones you wire up)
# ============================================================================
# Each source needs (a) credentials and (b) a webhook signing secret so the
# engine can verify inbound webhooks in-process (no gateway in self-host).
# See docs/connectors.md for how to create each app.

# GitHub: register your own GitHub App; the engine mints installation tokens
# locally. GITHUB_APP_PRIVATE_KEY is the PEM contents (keep the newlines).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Slack / Linear / Notion / Sentry
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
NOTION_CLIENT_SECRET=
NOTION_WEBHOOK_VERIFICATION_TOKEN=
SENTRY_CLIENT_SECRET=
SENTRY_WEBHOOK_SECRET=

# ============================================================================
# OPTIONAL
# ============================================================================
# Route all LLM/embedding calls through a LiteLLM-compatible gateway instead of
# the provider SDKs. Leave blank to call providers directly with the keys above.
LLM_GATEWAY_URL=
LLM_GATEWAY_KEY=

# Observability (OTLP).
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_HEADERS=

# ============================================================================
# HOSTED ONLY — leave BLANK for self-host
# ============================================================================
# Set by Probe's managed control plane; activating these switches the engine to
# multi-tenant gateway-trust mode (per-request tenant + backend-minted tokens).
# A self-hoster normally leaves these blank.
#
# Exception: INTERNAL_KNOWLEDGE_API_KEY also gates the internal push API
# (POST /api/custom-ingest/documents). A self-hoster who wants to push docs via
# that API (rather than signed webhooks) can set it + send X-Prbe-Customer:
# <DEFAULT_CUSTOMER_ID>. NOTE: setting it makes /webhooks/{source} require this
# key instead of per-provider signatures, so it's gateway-mode OR signature-mode,
# not both. /query always works via KNOWLEDGE_API_TOKEN regardless.
INTERNAL_KNOWLEDGE_API_KEY=
BACKEND_BASE_URL=
INTERNAL_BACKEND_API_KEY=

# MCP OAuth (hosted): the MCP validates customer-agent JWTs against the issuer
# JWKS. With MCP_AUTH_MODE unset, the MCP auto-resolves to oauth mode when
# MCP_OAUTH_JWKS_URL is set (and to static when only MCP_API_TOKEN is set).
MCP_OAUTH_JWKS_URL=
MCP_OAUTH_ISSUER=https://auth.example.com
MCP_OAUTH_AUDIENCE=https://mcp.example.com
