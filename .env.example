# Copy to .env.local and fill in your values. .env.local is gitignored.

# Database (local docker-compose default matches these)
DATABASE_URL=postgresql+asyncpg://prbe:prbe@localhost:5432/prbe_knowledge
DATABASE_URL_SYNC=postgresql://prbe:prbe@localhost:5432/prbe_knowledge

# Storage (local MinIO defaults)
R2_ENDPOINT_URL=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_REGION=auto

# LLM / embedding providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for /query auth (dev only)
RETRIEVAL_SHARED_SECRET=dev-secret-change-me

# Fernet key for encrypting OAuth tokens at rest
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# OAuth app credentials (5 sources)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# Observability (optional for local dev)
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_HEADERS=
