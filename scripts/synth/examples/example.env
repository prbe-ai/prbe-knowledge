# =============================================================================
# example.env — every environment variable the synth pipeline reads.
#
# Source this file (or a copy) before invoking `synth init / extract / run`,
# or pass --env <path> to scripts/synth/dev/seed_to_customer.sh which sources
# it for you.
#
# THIS FILE IS A TEMPLATE — replace placeholder values with real ones, then
# save as `.env.local` (gitignored) or wherever you keep secrets. DO NOT
# commit a populated copy.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED for `synth init`, `synth run --integrate`, and the worker.
# -----------------------------------------------------------------------------

# REQUIRED. Async Postgres URL (asyncpg-compatible, plain postgresql:// scheme).
# Used by every synth subcommand that touches the DB at runtime.
DATABASE_URL=postgresql://prbe:prbe@localhost:5432/prbe_knowledge

# REQUIRED. Sync Postgres URL (psycopg-compatible, postgresql+psycopg:// scheme).
# Used by alembic migrations and some sync code paths in the worker.
DATABASE_URL_SYNC=postgresql+psycopg://prbe:prbe@localhost:5432/prbe_knowledge

# REQUIRED. Object-storage endpoint. Local: MinIO; Prod: Cloudflare R2.
R2_ENDPOINT_URL=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_REGION=auto

# REQUIRED. Fernet key used to encrypt integration_tokens.access_token_encrypted.
# Generate once: `python -c "from shared.encryption import generate_key; print(generate_key())"`
# MUST match between `synth init` (encrypts) and the worker (decrypts) — keep
# the same value for the duration of a tenant's lifecycle, or re-init the tenant.
TOKEN_ENCRYPTION_KEY=PASTE_GENERATED_FERNET_KEY_HERE

# -----------------------------------------------------------------------------
# REQUIRED for `synth run` in real-LLM mode (i.e. without --mock-llm).
# -----------------------------------------------------------------------------

# REQUIRED for any Anthropic-prefixed model in your preset/profile `llm:` block.
# Default presets use claude-* models for all three roles, so this is required
# unless you explicitly override every role to a non-Anthropic provider.
ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE

# REQUIRED for the worker's embedding step (text-embedding-3-large) when
# `synth run --integrate` is used. NOT strictly needed for `synth run` alone
# without --integrate, but the worker downstream needs it to embed docs.
OPENAI_API_KEY=sk-PASTE-YOUR-KEY-HERE

# OPTIONAL. Required only if your preset/profile uses any `gemini-*` model id.
# Synth can mix providers across roles (planner / writer / validator).
# GOOGLE_API_KEY=PASTE-YOUR-KEY-HERE

# -----------------------------------------------------------------------------
# OPTIONAL — improves the WorldModel extraction.
# -----------------------------------------------------------------------------

# OPTIONAL. GitHub PAT with `repo` scope (read-only is fine).
# - If a profile.repos[*] entry has `local_path`, the extractor reads from disk
#   and skips GitHub entirely.
# - If `local_path` is omitted, the extractor clones via this token. Without
#   the token, repo extraction silently skips that repo with a warning.
# Used by: scripts/synth/cli.py:379, scripts/synth/cli.py:687
GITHUB_TOKEN=ghp_PASTE_YOUR_PAT_HERE

# -----------------------------------------------------------------------------
# OPTIONAL — only needed if you also stand up the retrieval API.
# -----------------------------------------------------------------------------

# OPTIONAL. Pre-shared key for service-to-service auth on the retrieval API.
# Required by the retrieval service itself (services/retrieval/main.py) and by
# clients hitting it (curl / dashboard). Not read by `synth init / run`.
# Generate with `uuidgen`. Convention: prefix with `dev-internal-`.
INTERNAL_KNOWLEDGE_API_KEY=dev-internal-REPLACE-WITH-UUID

# -----------------------------------------------------------------------------
# OPTIONAL — observability.
# -----------------------------------------------------------------------------

# OPTIONAL. OTLP endpoint for telemetry export. If unset, telemetry is no-op.
# Used by: shared/telemetry.py:18
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# NOT used by synth, but commonly co-located in the same .env for prbe-knowledge
# work. Listed here so you know what to expect if you copy from .env.example.
# -----------------------------------------------------------------------------
# BACKEND_BASE_URL=
# INTERNAL_BACKEND_API_KEY=
# SLACK_CLIENT_SECRET=
# LINEAR_CLIENT_SECRET=
# NOTION_CLIENT_SECRET=
# SENTRY_CLIENT_SECRET=
# GRAFANA_OTLP_ENDPOINT=
# GRAFANA_OTLP_HEADERS=
